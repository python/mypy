[case testSeparateCompilationWithUndefinedAttribute]
from other_a import A

def f() -> None:
    a = A()
    if a.x == 5:
        print(a.y)
        print(a.m())
    else:
        assert a.x == 6
        try:
            print(a.y)
        except AttributeError:
            print('y undefined')
        else:
            assert False

        try:
            print(a.m())
        except AttributeError:
            print('y undefined')
        else:
            assert False

