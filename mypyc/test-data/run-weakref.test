# Test cases for weakrefs (compile and run)

[case testWeakrefRef]
import pytest
from weakref import ref

def test_weakref_ref():
    obj = object()
    r = ref(obj)
    assert r() is obj
    del obj
    assert r() is None

def test_weakref_ref_with_callback():
    obj = object()
    r = ref(obj, lambda x: x)
    assert r() is obj
    del obj
    assert r() is None

[case testWeakrefProxy]
import pytest
from weakref import proxy

def test_weakref_proxy():
    class MyClass():
        def test(self):
            return True
    obj = MyClass()
    p = proxy(obj)
    assert p.test() is True
    del obj
    with pytest.raises(ReferenceError):
        p.test()

def test_weakref_proxy_with_callback():
    class MyClass():
        def test(self):
            return True
    obj = MyClass()
    p = proxy(obj, lambda x: x)
    assert p.test() is True
    del obj
    with pytest.raises(ReferenceError):
        p.test()
