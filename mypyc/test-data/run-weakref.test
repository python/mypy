# Test cases for weakrefs (compile and run)

[case testWeakrefRef]
import pytest  # type: ignore [import-not-found]
from weakref import ref

class MyClass:
    pass

def test_weakref_ref():
    obj = MyClass()
    r = ref(obj)
    assert r() is obj
    del obj
    assert r() is None

def test_weakref_ref_with_callback():
    obj = MyClass()
    r = ref(obj, lambda x: x)
    assert r() is obj
    del obj
    assert r() is None

[case testWeakrefProxy]
import pytest  # type: ignore [import-not-found]
from weakref import proxy

class MyClass:
    def do_thing(self):
        return True

def test_weakref_proxy():
    obj = MyClass()
    p = proxy(obj)
    assert p.do_thing() is True
    del obj
    with pytest.raises(ReferenceError):
        p.do_thing()

def test_weakref_proxy_with_callback():
    obj = MyClass()
    p = proxy(obj, lambda x: x)
    assert p.do_thing() is True
    del obj
    with pytest.raises(ReferenceError):
        p.do_thing()
